# ============================================================================
# Environment variables required by 3D Ninjaz
# Copy this file to .env.local and fill in real values. Do NOT commit .env.local.
# ============================================================================

# --- Database (Phase 1) ---
DATABASE_URL=mysql://user:password@host:3306/database

# --- SMTP / Email (Phase 1) ---
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
MAIL_FROM="3D Ninjaz <noreply@3dninjaz.com>"

# --- Better Auth (Phase 1) ---
BETTER_AUTH_SECRET=replace_with_32_byte_random_string
BETTER_AUTH_URL=http://localhost:3000

# --- PayPal (Phase 3) ---
# Switch: "live" uses PAYPAL_CLIENT_ID/SECRET, "sandbox" uses *_SANDBOX.
PAYPAL_ENV=sandbox

# Live credentials (PayPal Developer Dashboard -> Apps & Credentials -> Live app)
PAYPAL_CLIENT_ID=live_client_id_here
PAYPAL_CLIENT_SECRET=live_client_secret_here

# Sandbox credentials (PayPal Developer Dashboard -> Apps & Credentials -> Sandbox app)
PAYPAL_CLIENT_ID_SANDBOX=sandbox_client_id_here
PAYPAL_CLIENT_SECRET_SANDBOX=sandbox_client_secret_here

# Payment currency — MYR for Malaysian business accounts.
PAYPAL_CURRENCY=MYR

# Public client ID consumed by @paypal/react-paypal-js in the browser.
# Same value as PAYPAL_CLIENT_ID (live) — never expose the secret.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=live_client_id_here
NEXT_PUBLIC_PAYPAL_CURRENCY=MYR

# Webhook ID from PayPal Developer Dashboard -> app -> Webhooks (used in Plan 02)
PAYPAL_WEBHOOK_ID=webhook_id_here

# Sandbox buyer (populated automatically when you create a sandbox business account)
PAYPAL_SANDBOX_BUYER_EMAIL=
PAYPAL_SANDBOX_BUYER_PASSWORD=

# Delyva — delivery integration (get from my.delyva.app -> Settings -> API Integrations)
DELYVA_BASE_URL=https://api.delyva.app/v1.0
DELYVA_API_KEY=
DELYVA_COMPANY_CODE=
DELYVA_COMPANY_ID=
DELYVA_USER_ID=
DELYVA_CUSTOMER_ID=
DELYVA_API_SECRET=
DELYVA_WEBHOOK_SHARED_SECRET=
