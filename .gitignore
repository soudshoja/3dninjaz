# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.example

# Local-disk product uploads (keep the folder tracked via .gitkeep, ignore its contents)
/public/uploads/products/*
!/public/uploads/products/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local dev artifacts (screenshots, deploy scripts, playwright logs)
/.playwright-mcp/
/_deploy/
/deploy-v1.tar.gz
/coming-soon.zip
/basilisa-*.png
/coming-soon-*.png
/coming-soon.zip
/demo-*.png
/demo-v2-*.png
/live-*.png
/dev.log
# SEO audit reports (regenerate on demand)
/seo-audit-*.md
/seo-baseline-report.md
# Raw image assets (use /public/ instead)
/logo.jpeg
/logo.png
/logopng.png
/ninjalogo.jpeg
/example.jpeg

# Phase 7 (07-01) — recon JSON snapshots are gitignored (PayPal txn IDs are
# sensitive per T-07-X-recon-leak)
.planning/intel/

# Claude Code local config — skills, settings, plugin metadata
.claude/
backups/
public/logo-original-backup.png
